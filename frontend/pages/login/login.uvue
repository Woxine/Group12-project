<template>
	<view class="back">
		<image src="/static/login_back1.jpg" mode="" class="backpic"></image>
		
		<view class="login_title">
			<text class="title_text">log in</text>
		</view>
		
		<view class="login_container">
			<!-- 第一个输入框绑定 email -->
			<input 
        v-model="userInfo.email" 
        type="text" 
        placeholder="please enter your email" 
        confirm-type="next" 
        class="input"
      />
			<view class="span1"></view>
			<!-- 第二个输入框绑定 password -->
			<input 
        v-model="userInfo.password" 
        type="password" 
        placeholder="please enter your password" 
        class="input"
      />
			<view class="span2"></view>
			<!-- 登录按钮绑定点击事件 -->
			<button 
        @click="onSubmit" 
        size="default" 
        :disabled="isSubmitting" 
        style="color: white;background-color: rgba(60, 60, 60, 0.7);">
				{{ isSubmitting ? 'Logging in...' : 'log in' }}
			</button>
			<view class="span3"></view>
			<navigator url="/pages/register/register" open-type="reLaunch">
				<button size="default" style="color: white;background-color: rgba(60, 60, 60, 0.7);">sign up</button>
			</navigator>
		</view>
	</view>
	
	<view class="bottom">
		<navigator url="/pages/index/index" open-type="reLaunch" class="bottom_left">
			<image src="/static/home.png" mode="aspectFit" class="icon2"></image>
			<view class="left_down"><text class="text3">Home</text></view>
		</navigator>
		<navigator url="/pages/bikelist/bikelist" open-type="reLaunch" class="bottom_center">
			<image src="/static/bike.png" mode="aspectFit" class="bike_icon"></image>
			<view class="center_down"><text class="text3">Bike</text></view>
		</navigator>
		<view class="bottom_right">
			<image src="/static/me.png" mode="aspectFit" class="icon2"></image>
			<view class="right_down"><text class="text3">Me</text></view>
		</view>
	</view>
</template>

<script setup>
import { reactive, ref } from 'vue';

// 响应式数据对象，用于存储用户输入
type UserInfo = {
	email: string
	password: string
}
const userInfo = reactive<UserInfo>({
	email: '',
	password: ''
});

// 控制提交状态，防止重复提交
const isSubmitting = ref(false);

// 定义提交方法
const onSubmit = () => {
	// 防止重复提交
	if (isSubmitting.value) return;

	// 简单校验
	if (userInfo.email == null || userInfo.email == '' || userInfo.password == null || userInfo.password == '') {
		uni.showToast({
			title: 'Please fill in both email and password.',
			icon: 'none'
		});
		return;
	}

	isSubmitting.value = true;

	uni.request({
		url: 'http://192.168.31.246:8080/api/v1/auth/login', // 请求的 API 地址
		method: 'POST',
		data: {
			email: userInfo.email,
			password: userInfo.password
		},
		header: {
			'Content-Type': 'application/json'
		},
		success: (res) => {
			console.log('Login API Response:', res.data);
			
			// 后端返回结构为 { "data": { "token": "...", "userId": "...", "role": "..." } }
			const ret = res.data as UTSJSONObject
			
			// 只要状态码是 200，且 data 字段存在，就认为成功
			if (res.statusCode === 200) {
				// 检查是一层结构还是两层结构
				// 如果后端直接返回对象，或者包了一层 'data'
				let loginData: UTSJSONObject | null = null;
				
				if (ret['data'] != null) {
					loginData = ret['data'] as UTSJSONObject;
				} else {
					// 兼容性尝试：也许直接返回了字段
					loginData = ret;
				}
				
				if (loginData != null) {
					const token = loginData['token'] as string | null
					if (token != null) {
						uni.setStorage({
							key: 'token',
							data: token
						})
						
						uni.showToast({
							title: 'Login successful!',
							icon: 'success'
						});
						
						// 跳转到首页
						setTimeout(() => {
							uni.reLaunch({ url: '/pages/index/index' });
						}, 1500);
						return;
					}
				}
			} 
			
			// 失败流程
			const retObj = res.data as UTSJSONObject
			// 默认错误消息
			let msg = 'Login failed. Please check your credentials.';
			
			// 尝试提取后端详细错误信息
			// 后端通常返回 { "message": "...", "error": "..." }
			const backendMsg = retObj['message'];
			const backendErr = retObj['error'];
			
			if (backendMsg != null) {
				msg = backendMsg as string;
			} else if (backendErr != null) {
				msg = `Error: ${backendErr}`;
			}
			
			console.error('Login failed. Status:', res.statusCode, 'Response:', JSON.stringify(retObj));
			
			uni.showToast({
				title: msg,
				icon: 'none',
				duration: 3000
			});
		},
		fail: (err) => {
			console.error('Login request failed:', err);
			uni.showToast({
				title: 'Network error, please try again later.',
				icon: 'none'
			});
		},
		complete: () => {
			// 请求完成后，无论成功失败都重置提交状态
			isSubmitting.value = false;
		}
	});
};
</script>

