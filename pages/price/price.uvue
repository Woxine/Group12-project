<template>
	<!-- 时长选择页：选择开始/结束时间，显示费用预估及定价参考卡片 -->
	<view class="container">
		<scroll-view scroll-y="true" class="scroll-area">
			<view class="title">
				<text class="title-text">Select Booking Duration</text>
			</view>

			<!-- Start Time Selection -->
			<view class="time-section">
				<view class="section-title">
					<text class="section-title-text">Start Time</text>
				</view>
				<view class="time-input" @click="selectStartTime">
					<text class="time-label">Select Start Time</text>
					<text class="time-value">{{ startTime.length > 0 ? startTime : 'Not Selected' }}</text>
				</view>
			</view>

			<!-- End Time Selection -->
			<view class="time-section">
				<view class="section-title">
					<text class="section-title-text">End Time</text>
				</view>
				<view class="time-input" @click="selectEndTime">
					<text class="time-label">Select End Time</text>
					<text class="time-value">{{ endTime.length > 0 ? endTime : 'Not Selected' }}</text>
				</view>
			</view>

			<!-- Estimated Total -->
			<view v-if="startTime.length > 0 && endTime.length > 0" class="estimated-total-section">
				<view class="estimated-total-row">
					<text class="estimated-total-label">Estimated Total</text>
					<text class="estimated-total-value">£{{ estimatedTotalDisplay }}</text>
				</view>
			</view>

			<view class="button-group">
				<button class="confirm-btn" @click="confirm">Confirm</button>
				<button class="cancel-btn" @click="cancel">Cancel</button>
			</view>

			<!-- Pricing Reference (moved to bottom) -->
			<view class="pricing-ref-title">
				<text class="pricing-ref-title-text">Pricing Reference</text>
			</view>
			<view class="duration-cards">
				<view 
					v-for="(duration, index) in durations" 
					:key="index" 
					class="card"
				>
					<view class="card-header">
						<text class="duration">{{ duration.time }}</text>
					</view>
					<view class="card-body">
						<text class="price">£{{ duration.price }}</text>
					</view>
				</view>
			</view>
		</scroll-view>
	</view>
</template>

<script setup lang="uts">
// 时长选择逻辑：获取时价、计算费用、校验滑板车可用性并创建预订记录
import { ref, onMounted } from 'vue';
import { onShow } from '@dcloudio/uni-app';
import { BASE_URL } from '../../common/api.uts';

type DurationItem = {
	time: string;
	price: string;
}

type UserInfo = {
	name: string;
	email: string;
}

const hourRate = ref<number>(1.0);

const formatPrice = (val: number): string => {
	const rounded = Math.round(val * 100) / 100;
	const intPart = Math.floor(rounded);
	const decPart = Math.round((rounded - intPart) * 100);
	const decStr = decPart < 10 ? '0' + decPart : '' + decPart;
	return intPart + '.' + decStr;
};

const durations = ref<DurationItem[]>([
	{ time: '10 Minutes', price: '0.00' } as DurationItem,
	{ time: '1 Hour', price: '0.00' } as DurationItem,
	{ time: '4 Hours', price: '0.00' } as DurationItem,
	{ time: '1 Day', price: '0.00' } as DurationItem,
	{ time: '1 Week', price: '0.00' } as DurationItem
]);

const updateDurations = () => {
	const rate = hourRate.value;
	const items: DurationItem[] = [
		{ time: '10 Minutes', price: formatPrice(rate * 10 / 60) } as DurationItem,
		{ time: '1 Hour', price: formatPrice(rate * 1) } as DurationItem,
		{ time: '4 Hours', price: formatPrice(rate * 4) } as DurationItem,
		{ time: '1 Day', price: formatPrice(rate * 24) } as DurationItem,
		{ time: '1 Week', price: formatPrice(rate * 168) } as DurationItem
	];
	durations.value = items;
};

const startTime = ref<string>('');
const endTime = ref<string>('');
const durationCode = ref<string>('');
const estimatedTotalDisplay = ref<string>('0.00');

const updateEstimatedTotal = () => {
	if (startTime.value.length > 0 && endTime.value.length > 0) {
		const startDateObj = new Date(startTime.value);
		const endDateObj = new Date(endTime.value);
		const durationMs = endDateObj.getTime() - startDateObj.getTime();
		const durationHours = durationMs / (1000 * 60 * 60);
		const total = durationHours * hourRate.value;
		estimatedTotalDisplay.value = formatPrice(total);
	}
};

const fetchHourRate = () => {
	const selectedScooterId = uni.getStorageSync('selectedScooterId');
	if (selectedScooterId == null || selectedScooterId == '') {
		updateDurations();
		return;
	}
	let scooterId: string = '' + selectedScooterId;
	let numericId: string = '';
	for (let i = 0; i < scooterId.length; i++) {
		const ch = scooterId.charAt(i);
		if (ch >= '0' && ch <= '9') {
			numericId += ch;
		}
	}
	if (numericId.length == 0) {
		numericId = scooterId;
	}
	uni.request({
		url: BASE_URL + '/api/v1/scooters/' + numericId + '/location?_t=' + Date.now(),
		method: 'GET',
		header: { 'Cache-Control': 'no-cache' },
		success: (res) => {
			if (res.statusCode >= 200 && res.statusCode < 300 && res.data != null) {
				const resObj = res.data as UTSJSONObject;
				const dataObj = resObj['data'] as UTSJSONObject | null;
				if (dataObj != null) {
					const rateVal = dataObj['hourRate'];
					if (rateVal != null) {
						hourRate.value = rateVal as number;
					}
				}
			}
			updateDurations();
			updateEstimatedTotal();
		},
		fail: () => {
			updateDurations();
		}
	});
};

onMounted(() => {
	fetchHourRate();
});

onShow(() => {
	fetchHourRate();
});

const selectStartTime = () => {
	const now = new Date();
	const currentHour = now.getHours().toString().padStart(2, '0');
	const currentMinute = now.getMinutes().toString().padStart(2, '0');
	const currentDate = now.getFullYear() + '-' +
		(now.getMonth() + 1).toString().padStart(2, '0') + '-' +
		now.getDate().toString().padStart(2, '0');

	uni.showActionSheet({
		itemList: ['Start Now', '1 Hour Later', '2 Hours Later', '3 Hours Later'],
		success: (res) => {
			if (res.tapIndex == 0) {
				startTime.value = currentDate + ' ' + currentHour + ':' + currentMinute;
			} else if (res.tapIndex == 1) {
				const time1 = new Date(now.getTime() + 60 * 60 * 1000);
				startTime.value = currentDate + ' ' + time1.getHours().toString().padStart(2, '0') + ':' + time1.getMinutes().toString().padStart(2, '0');
			} else if (res.tapIndex == 2) {
				const time2 = new Date(now.getTime() + 2 * 60 * 60 * 1000);
				startTime.value = currentDate + ' ' + time2.getHours().toString().padStart(2, '0') + ':' + time2.getMinutes().toString().padStart(2, '0');
			} else if (res.tapIndex == 3) {
				const time3 = new Date(now.getTime() + 3 * 60 * 60 * 1000);
				startTime.value = currentDate + ' ' + time3.getHours().toString().padStart(2, '0') + ':' + time3.getMinutes().toString().padStart(2, '0');
			}
			endTime.value = '';
			durationCode.value = '';
			estimatedTotalDisplay.value = '0.00';
		}
	});
};

const selectEndTime = () => {
	if (startTime.value == '') {
		uni.showToast({ title: 'Please select start time first', icon: 'none' });
		return;
	}

	const startDate = new Date(startTime.value);

	uni.showActionSheet({
		itemList: ['10 Minutes Later', '1 Hour Later', '4 Hours Later', '1 Day Later', '1 Week Later'],
		success: (res) => {
			let endDateTime: Date | null = null;
			let duration: string = '';

			if (res.tapIndex == 0) {
				endDateTime = new Date(startDate.getTime() + 10 * 60 * 1000);
				duration = '10M';
			} else if (res.tapIndex == 1) {
				endDateTime = new Date(startDate.getTime() + 1 * 60 * 60 * 1000);
				duration = '1H';
			} else if (res.tapIndex == 2) {
				endDateTime = new Date(startDate.getTime() + 4 * 60 * 60 * 1000);
				duration = '4H';
			} else if (res.tapIndex == 3) {
				endDateTime = new Date(startDate.getTime() + 24 * 60 * 60 * 1000);
				duration = '1D';
			} else if (res.tapIndex == 4) {
				endDateTime = new Date(startDate.getTime() + 7 * 24 * 60 * 60 * 1000);
				duration = '1W';
			}

			if (endDateTime != null) {
				const ed = endDateTime as Date;
				const endDateStr = ed.getFullYear() + '-' +
					(ed.getMonth() + 1).toString().padStart(2, '0') + '-' +
					ed.getDate().toString().padStart(2, '0');
				endTime.value = endDateStr + ' ' + ed.getHours().toString().padStart(2, '0') + ':' + ed.getMinutes().toString().padStart(2, '0');
				durationCode.value = duration;
				updateEstimatedTotal();
			}
		}
	});
};

const pendingScooterId = ref<string>('');
const pendingUserId = ref<string>('');
const pendingToken = ref<string>('');
const pendingTotalPrice = ref<number>(0);

const stepSendBooking = () => {
	const token = pendingToken.value;
	const bookingData: UTSJSONObject = {
		'user_id': pendingUserId.value,
		'userId': pendingUserId.value,
		'scooter_id': pendingScooterId.value,
		'start_time': startTime.value,
		'end_time': endTime.value,
		'duration': durationCode.value,
		'total_price': pendingTotalPrice.value,
		'status': 'CONFIRMED'
	};
	console.log('Booking info:', bookingData);
	uni.request({
		url: BASE_URL + '/api/v1/bookings',
		method: 'POST',
		data: bookingData,
		header: {
			'Content-Type': 'application/json',
			'Authorization': 'Bearer ' + token
		},
		success: (res) => {
			console.log('Booking response:', res.statusCode);
			if (res.statusCode >= 200 && res.statusCode < 300) {
				uni.showToast({ title: 'Booking successful, proceed to payment', icon: 'success' });
				setTimeout(() => { uni.navigateTo({ url: '/pages/payment/payment' }); }, 1000);
			} else {
				let errorMsg: string = 'Booking failed, please try again';
				const errorData = res.data as UTSJSONObject | null;
				if (errorData != null) {
					const msg = errorData['message'];
					const err = errorData['error'];
					const detail = errorData['detail'];
					if (msg != null) {
						errorMsg = '' + msg;
					} else if (err != null) {
						errorMsg = '' + err;
					} else if (detail != null) {
						errorMsg = '' + detail;
					}
				}
				if (res.statusCode == 401) {
					uni.showToast({ title: 'Login expired, please login again', icon: 'none', duration: 2500 });
					setTimeout(() => { uni.reLaunch({ url: '/pages/login/login' }); }, 2500);
				} else {
					const msgLower = errorMsg.toLowerCase();
					if (msgLower.indexOf('bookingresponse') >= 0 || msgLower.indexOf('type definition error') >= 0) {
						errorMsg = 'Booking service error, please try again later';
					}
					uni.showToast({ title: errorMsg, icon: 'none', duration: 3000 });
					const isScooterUnavailable = msgLower.indexOf('overlapping') >= 0 || msgLower.indexOf('not available') >= 0;
					if (isScooterUnavailable) {
						setTimeout(() => { uni.navigateBack({}); }, 3000);
					}
				}
			}
		},
		fail: () => {
			uni.showToast({ title: 'Network error, please try again', icon: 'none' });
		}
	});
};

const stepGetLocationAndBook = () => {
	uni.getLocation({
		type: 'gcj02',
		success: (locRes) => {
			pendingScooterId.value = pendingScooterId.value;
			console.log('Got location, creating booking');
			stepSendBooking();
		},
		fail: () => {
			console.log('Location unavailable, creating booking without location');
			stepSendBooking();
		}
	});
};

const hasActivePending = ref<boolean>(false);

const stepAfterActiveCheck = () => {
	console.log('stepAfterActiveCheck, hasActive:', hasActivePending.value);
	if (hasActivePending.value) {
		uni.showToast({ title: 'You already have an active booking.', icon: 'none', duration: 3000 });
	} else {
		setTimeout(() => { stepGetLocationAndBook(); }, 10);
	}
};

const stepCheckActiveBooking = () => {
	const userId = pendingUserId.value;
	const token = pendingToken.value;
	console.log('Checking active bookings for user:', userId);
	hasActivePending.value = false;
	uni.request({
		url: BASE_URL + '/api/v1/users/' + userId + '/bookings',
		method: 'GET',
		header: {
			'Content-Type': 'application/json',
			'Authorization': 'Bearer ' + token
		},
		success: (checkRes) => {
			console.log('Active booking check response:', checkRes.statusCode);
			if (checkRes.statusCode >= 200 && checkRes.statusCode < 300 && checkRes.data != null && typeof checkRes.data == 'object') {
				const obj = checkRes.data as UTSJSONObject;
				const list = obj['data'];
				if (list != null && Array.isArray(list)) {
					const arr = list as UTSJSONObject[];
					for (let i = 0; i < arr.length; i++) {
						const rawStatus = arr[i]['status'];
						const s = rawStatus != null ? ('' + rawStatus).toUpperCase() : '';
						if (s == 'CONFIRMED' || s == 'PENDING') {
							hasActivePending.value = true;
							break;
						}
					}
				}
			}
			setTimeout(() => { stepAfterActiveCheck(); }, 10);
		},
		fail: () => {
			console.log('Active booking check FAILED');
			uni.showToast({ title: 'Failed to check bookings', icon: 'none' });
		}
	});
};

const scooterAvailable = ref<boolean>(true);

const stepAfterScooterCheck = () => {
	console.log('stepAfterScooterCheck, available:', scooterAvailable.value);
	if (scooterAvailable.value) {
		setTimeout(() => { stepCheckActiveBooking(); }, 10);
	} else {
		uni.showToast({ title: 'This scooter is no longer available.', icon: 'none', duration: 3000 });
		setTimeout(() => { uni.navigateBack({}); }, 3000);
	}
};

const stepCheckScooter = () => {
	const scooterId = pendingScooterId.value;
	console.log('Checking scooter availability:', scooterId);
	scooterAvailable.value = true;
	uni.request({
		url: BASE_URL + '/api/v1/scooters/' + scooterId + '/location?_t=' + Date.now(),
		method: 'GET',
		header: { 'Cache-Control': 'no-cache' },
		success: (scooterRes) => {
			console.log('Scooter check response:', scooterRes.statusCode);
			if (scooterRes.statusCode >= 200 && scooterRes.statusCode < 300 && scooterRes.data != null) {
				const scooterObj = scooterRes.data as UTSJSONObject;
				const scooterData = scooterObj['data'] as UTSJSONObject | null;
				if (scooterData != null) {
					const currentStatus = scooterData['status'];
					if (currentStatus != null && ('' + currentStatus).toUpperCase() != 'AVAILABLE') {
						scooterAvailable.value = false;
					}
				}
			}
			setTimeout(() => { stepAfterScooterCheck(); }, 10);
		},
		fail: () => {
			console.log('Scooter check FAILED');
			uni.showToast({ title: 'Failed to verify scooter availability', icon: 'none' });
		}
	});
};

const confirm = () => {
	if (startTime.value == '' || endTime.value == '') {
		const msg = startTime.value == '' ? 'Please select start time' : 'Please select end time';
		uni.showToast({ title: msg, icon: 'none' });
	} else {
		const tokenRaw = uni.getStorageSync('token');
		const token = tokenRaw != null ? ('' + tokenRaw).trim() : '';
		const userIdStorage = uni.getStorageSync('userId');
		let userId: string = '';
		if (userIdStorage != null) {
			userId = '' + userIdStorage;
		}

		if (token.length == 0) {
			uni.showToast({ title: 'Please login first', icon: 'none' });
		} else if (userId.length == 0) {
			uni.showToast({ title: 'User information missing', icon: 'none' });
		} else {
			const selectedScooterId = uni.getStorageSync('selectedScooterId');
			let scooterId: string = selectedScooterId != null ? selectedScooterId as string : 'SC001';
			let numericScooterId: string = '';
			for (let i = 0; i < scooterId.length; i++) {
				const ch = scooterId.charAt(i);
				if (ch >= '0' && ch <= '9') {
					numericScooterId += ch;
				}
			}
			if (numericScooterId.length == 0) {
				numericScooterId = scooterId;
			}

			const startDateObj = new Date(startTime.value);
			const endDateObj = new Date(endTime.value);
			const durationMs = endDateObj.getTime() - startDateObj.getTime();
			const durationHours = durationMs / (1000 * 60 * 60);
			const totalPrice = durationHours * hourRate.value;

			console.log('Total Price:', totalPrice, 'Scooter:', numericScooterId);

			pendingScooterId.value = numericScooterId;
			pendingUserId.value = userId;
			pendingToken.value = token;
			pendingTotalPrice.value = totalPrice;
			setTimeout(() => { stepCheckScooter(); }, 10);
		}
	}
};

const cancel = () => {
	startTime.value = '';
	endTime.value = '';
	uni.showToast({ title: 'Cancelled', icon: 'none' });
	uni.reLaunch({ url: '/pages/index/index' });
};
</script>

<style lang="scss">
