<template>
	<view class="container">
		<view class="scroll-wrap" :style="{ height: scrollWrapHeight + 'px' }">
			<scroll-view class="scroll-area" direction="vertical" scroll-y="true" show-scrollbar="true" enable-back-to-top="true" :style="{ height: scrollViewHeight + 'px' }">
				<view class="hero-card">
					<image :src="avatarUrl" mode="aspectFill" class="avatar"></image>
					<view class="hero-copy">
						<text class="title">Account Management</text>
						<text class="hero-name">{{ userName }}</text>
						<text class="hero-email">{{ userEmail }}</text>
						<text class="hint">Manage your avatar and sign-in details in one place.</text>
					</view>
				</view>

				<view class="section-card">
					<text class="section-title">Profile</text>

					<navigator url="/pages/portrait/portrait" open-type="navigate" class="menu-item">
						<view class="menu-leading avatar-item-icon">
							<text class="menu-leading-text">📷</text>
						</view>
						<view class="menu-copy">
							<text class="menu-title">Change Avatar</text>
							<text class="menu-hint">Update your profile picture.</text>
						</view>
						<text class="menu-arrow">›</text>
					</navigator>

					<navigator url="/pages/username/username" open-type="navigate" class="menu-item">
						<view class="menu-leading username-item-icon">
							<text class="menu-leading-text">👤</text>
						</view>
						<view class="menu-copy">
							<text class="menu-title">Change Username</text>
							<text class="menu-hint">Set a new display name for your account.</text>
						</view>
						<text class="menu-arrow">›</text>
					</navigator>
				</view>

				<view class="section-card">
					<text class="section-title">Security</text>

					<navigator url="/pages/email/email" open-type="navigate" class="menu-item">
						<view class="menu-leading email-item-icon">
							<text class="menu-leading-text">✉</text>
						</view>
						<view class="menu-copy">
							<text class="menu-title">Change Email</text>
							<text class="menu-hint">Update the email address linked to your account.</text>
						</view>
						<text class="menu-arrow">›</text>
					</navigator>

					<navigator url="/pages/password/password" open-type="navigate" class="menu-item">
						<view class="menu-leading password-item-icon">
							<text class="menu-leading-text">🔑</text>
						</view>
						<view class="menu-copy">
							<text class="menu-title">Change Password</text>
							<text class="menu-hint">Keep your account secure with a new password.</text>
						</view>
						<text class="menu-arrow">›</text>
					</navigator>
				</view>

				<view class="section-card">
					<text class="section-title">Benefits</text>

					<navigator url="/pages/discount-verification/discount-verification" open-type="navigate" class="menu-item">
						<view class="menu-leading discount-item-icon">
							<text class="menu-leading-text">🎓</text>
						</view>
						<view class="menu-copy">
							<text class="menu-title">Discount Verification</text>
							<text class="menu-hint">Upload proof to apply for student or senior discounts.</text>
						</view>
						<text class="menu-arrow">›</text>
					</navigator>
				</view>

			</scroll-view>
		</view>
	</view>
</template>

<script setup lang="uts">
import { ref, onMounted } from 'vue'
import { onShow } from '@dcloudio/uni-app'

const DEFAULT_AVATAR = '/static/me.png'
const AVATAR_STORAGE_KEY_PREFIX = 'userAvatar_'
const LEGACY_AVATAR_STORAGE_KEY = 'userAvatar'

const avatarUrl = ref(DEFAULT_AVATAR)
const userName = ref('Your Account')
const userEmail = ref('No email available')
const scrollWrapHeight = ref(600)
const scrollViewHeight = ref(560)

const setScrollHeight = () => {
	try {
		const sys = uni.getSystemInfoSync()
		const h = sys.windowHeight != null ? sys.windowHeight : 600
		scrollWrapHeight.value = h
		scrollViewHeight.value = h - 24
	} catch (e) {
		scrollWrapHeight.value = 600
		scrollViewHeight.value = 560
	}
}

const readStorageStringOrNull = (key: string): string | null => {
	const raw = uni.getStorageSync(key)
	if (raw == null) return null
	const value = ('' + raw).trim()
	return value.length < 1 ? null : value
}

const getAvatarStorageKey = (): string => {
	const userId = readStorageStringOrNull('userId')
	if (userId != null) {
		return AVATAR_STORAGE_KEY_PREFIX + userId
	}
	return LEGACY_AVATAR_STORAGE_KEY
}

const loadAvatar = () => {
	const avatarKey = getAvatarStorageKey()
	const savedAvatar = readStorageStringOrNull(avatarKey)
	if (savedAvatar != null) {
		avatarUrl.value = savedAvatar
		return
	}
	const legacyAvatar = readStorageStringOrNull(LEGACY_AVATAR_STORAGE_KEY)
	if (legacyAvatar != null) {
		avatarUrl.value = legacyAvatar
		uni.setStorageSync(avatarKey, legacyAvatar)
		return
	}
	avatarUrl.value = DEFAULT_AVATAR
}

const loadUserInfo = () => {
	userName.value = 'Your Account'
	userEmail.value = 'No email available'

	const userInfoRaw = uni.getStorageSync('userInfo')
	if (userInfoRaw == null || typeof userInfoRaw != 'string' || userInfoRaw.length == 0) return

	try {
		const userInfo = JSON.parse<UTSJSONObject>(userInfoRaw)!!
		const rawName = userInfo['name']
		const rawEmail = userInfo['email']
		if (rawName != null && ('' + rawName).trim().length > 0) {
			userName.value = ('' + rawName).trim()
		}
		if (rawEmail != null && ('' + rawEmail).trim().length > 0) {
			userEmail.value = ('' + rawEmail).trim()
		}
	} catch (e) {
		console.error('Failed to parse userInfo in account page:', e)
	}
}

onMounted(() => {
	setScrollHeight()
})

onShow(() => {
	setScrollHeight()
	loadAvatar()
	loadUserInfo()
})
</script>

