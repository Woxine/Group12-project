<template>
	<image src="/static/bikeline1.jpg" mode="aspectFill" class="bg-image"></image>
	
	<view class="container">
		<view class="bg-mask"></view>
		<view class="card">
			<text class="title">Change Password</text>
			<text class="hint">Please verify your current password before updating.</text>

			<input
				v-model="form.currentPassword"
				class="input"
				type="password"
				placeholder="Current Password"
				password
			/>
			<input
				v-model="form.newPassword"
				class="input"
				type="password"
				placeholder="New Password"
				password
			/>
			<input
				v-model="form.confirmPassword"
				class="input"
				type="password"
				placeholder="Confirm New Password"
				password
			/>

			<button class="submit-btn" :disabled="isSubmitting" @click="handleChangePassword">
				{{ isSubmitting ? 'Updating...' : 'Update Password' }}
			</button>
		</view>
	</view>
</template>

<script setup lang="uts">
import { reactive, ref } from 'vue'
import { BASE_URL } from '../../common/api.uts'
import { getAppMessage, getResponseMessage } from '../../common/messages.uts'
import { showSuccess, showError, showInfo, showThenNavigate } from '../../common/appToast.uts'

type PasswordForm = {
	currentPassword: string
	newPassword: string
	confirmPassword: string
}

const form = reactive<PasswordForm>({
	currentPassword: '',
	newPassword: '',
	confirmPassword: ''
})

const isSubmitting = ref(false)

const trimOrEmpty = (value: string): string => {
	return value == null ? '' : value.trim()
}


const handleChangePassword = () => {
	if (isSubmitting.value) return

	const currentPassword = trimOrEmpty(form.currentPassword)
	const newPassword = trimOrEmpty(form.newPassword)
	const confirmPassword = trimOrEmpty(form.confirmPassword)

	if (currentPassword.length == 0 || newPassword.length == 0 || confirmPassword.length == 0) {
		showInfo('Please complete all password fields')
		return
	}

	if (newPassword.length < 6) {
		showInfo('New password must be at least 6 characters')
		return
	}

	if (newPassword != confirmPassword) {
		showInfo('The two new passwords do not match')
		return
	}

	const userIdRaw = uni.getStorageSync('userId')
	const tokenRaw = uni.getStorageSync('token')
	const userId = userIdRaw == null ? '' : ('' + userIdRaw).trim()
	const token = tokenRaw == null ? '' : ('' + tokenRaw).trim()

	if (userId.length == 0 || token.length == 0) {
		showInfo(getAppMessage('auth', 'loginAgain', 'Please log in again'))
		uni.reLaunch({
			url: '/pages/login/login'
		})
		return
	}

	isSubmitting.value = true

	uni.request({
		url: BASE_URL + '/api/v1/users/' + userId + '/password',
		method: 'POST',
		data: {
			currentPassword: currentPassword,
			newPassword: newPassword
		},
		header: {
			'Content-Type': 'application/json',
			'Authorization': 'Bearer ' + token
		},
		success: (res) => {
			if (res.statusCode >= 200 && res.statusCode < 300) {
				showThenNavigate('Password changed successfully', '', true, 2000, 'navigateBack')

				form.currentPassword = ''
				form.newPassword = ''
				form.confirmPassword = ''
				return
			}

			const msg = getResponseMessage(res.data, 'Failed to change password')
			showError(msg)
		},
		fail: () => {
			showError(getAppMessage('network', 'requestFailedLater', 'Network error, please try again later.'))
		},
		complete: () => {
			isSubmitting.value = false
		}
	})
}
</script>

