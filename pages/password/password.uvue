	position: relative;
	width: 100%;
	max-width: 360px;
	background-color: rgba(255, 255, 255, 0.28);
	border-radius: 14px;
	padding: 22px 18px;
	box-sizing: border-box;
	border: 1px solid rgba(255, 255, 255, 0.4);
	box-shadow: 0 10px 26px rgba(0, 0, 0, 0.25);
	backdrop-filter: blur(12px);
	-webkit-backdrop-filter: blur(12px);
	z-index: 2;
}

.title {
	font-size: 20px;
	font-weight: 700;
	color: #f7fbff;
	//text-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
}

.hint {
	display: block;
	font-size: 12px;
	color: rgba(240, 247, 255, 0.95);
	margin-top: 8px;
	margin-bottom: 18px;
	//text-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
}

.input {
	width: 100%;
	height: 44px;
	background-color: rgba(255, 255, 255, 0.95);
	border: 1px solid #d8d8d8;
	border-radius: 8px;
	padding: 0 12px;
	font-size: 14px;
	color: #222222;
	box-sizing: border-box;
	margin-bottom: 12px;
}

.submit-btn {
	width: 100%;
	height: 44px;
	line-height: 44px;
	border-radius: 8px;
	color: #ffffff;
	background-color: #4caf50;
	font-size: 15px;
	font-weight: 600;
	margin-top: 6px;
}

.submit-btn[disabled] {
	opacity: 0.7;
}
</style>
