	</swiper>
	
	<!--
	<view class="span2">------</view>
	-->

	<view class="map_container">
		<map id="mainMap" class="map" :longitude="longitude" :latitude="latitude" :scale="scale" :markers="markers" show-location></map>
	</view>
	
	<!-- 预约按钮 -->
	<view class="booking-section">
		<button class="booking-button" @click="goToBikeList">
			appoint
